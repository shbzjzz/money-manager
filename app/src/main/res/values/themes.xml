<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose owns the real Material3 theme (see WealthFlowTheme in Theme.kt).
         This just controls the window before Compose content is drawn. -->
    <style name="Theme.WealthFlow" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:statusBarColor">@android:color/white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
